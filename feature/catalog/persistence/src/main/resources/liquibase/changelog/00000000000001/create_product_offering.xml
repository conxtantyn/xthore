<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <changeSet id="00000000000001-1" author="kevin-constantine">
        <createTable tableName="xt_product_offering">
            <column name="_id" type="bigserial">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="uuid" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="offering" type="varchar(255)">
                <constraints nullable="false"
                    foreignKeyName="fk_pf_offering"
                    referencedTableName="xt_offering"
                    referencedColumnNames="name"/>
            </column>
            <column name="product" type="uuid">
                <constraints nullable="false"
                    foreignKeyName="fk_pf_product"
                    referencedTableName="xt_product"
                    referencedColumnNames="uuid"/>
            </column>
            <column name="created_at" type="bigint" >
                <constraints nullable="false"/>
            </column>
        </createTable>
        <loadData
            file="liquibase/data/product_offering.csv"
            separator=","
            tableName="xt_product_offering"
            usePreparedStatements="true">
        </loadData>
    </changeSet>
</databaseChangeLog>
