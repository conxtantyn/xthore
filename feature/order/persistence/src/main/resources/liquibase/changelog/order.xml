<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <property name="now" value="now()" dbms="h2, mysql, postgresql"/>
    <property name="floatType" value="float" dbms="h2, mysql, postgresql"/>
    <property name="clobType" value="clob" dbms="h2, mysql, postgresql"/>
    <property name="uuidType" value="varchar(36)" dbms="h2, mysql, postgresql"/>
    <property name="datetimeType" value="datetime" dbms="h2, mysql, postgresql"/>

    <includeAll path="liquibase/changelog/00000000000001" />
</databaseChangeLog>
